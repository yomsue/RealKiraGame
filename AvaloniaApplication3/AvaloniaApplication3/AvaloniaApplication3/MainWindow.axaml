<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="AvaloniaApplication3.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Система Учета Судеб — Авторизация"
        Width="400" Height="450"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#1C1C1C">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*, Auto, *" Margin="30">
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="DEATH NOTE" FontSize="28" FontWeight="Bold" Foreground="White" LetterSpacing="5" HorizontalAlignment="Center"/>
            <TextBlock Text="Digital Destiny Management" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="15" Width="280">
            <StackPanel Spacing="5">
                <TextBlock Text="Имя Бога Смерти (Логин)" Foreground="#AAAAAA" FontSize="12"/>
                <TextBox Name="TxtUser" KeyDown="TxtUser_KeyDown" PlaceholderText="Введите имя..." Background="#2D2D2D" Foreground="White" BorderBrush="#444444"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Секретный ключ (Пароль)" Foreground="#AAAAAA" FontSize="12"/>
                <TextBox Name="TxtPass" PlaceholderText="Введите пароль..." PasswordChar="•" Background="#2D2D2D" Foreground="White" BorderBrush="#444444"/>
            </StackPanel>

            <Button Name="BtnLogin" Click="BtnLogin_Click" Content="Установить связь" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="12" Margin="0,10,0,0" Background="#4A1525" Foreground="White" FontWeight="Bold"/>
            <TextBlock Name="LblError" Foreground="#FF4F4F" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
            <TextBlock Text="Внимание: действия записываются в базу данных" FontSize="10" Foreground="#555555" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>