<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="520"
        x:Class="AvaloniaApplication3.MainBoardWindow"
        Title="АРМ Бога Смерти — Панель Управления Судьбами"
        Width="780" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="#141414">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="#1C1C1C" Padding="15,20" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="СИСТЕМА УЧЕТА СУДЕБ" FontSize="18" FontWeight="Bold" Foreground="White" LetterSpacing="2"/>
                    <TextBlock Text="Текущий пользователь: Рюк (Статус: Бог Смерти)" FontSize="11" Foreground="#888888" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" TabStripPlacement="Left" Padding="25,10,10,10" Margin="10,15,10,10" Background="#141414">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Width" Value="170"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Padding" Value="10,0,0,0"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </TabControl.Styles>
            
            <TabItem Header="📓 Внести имя">
                <ScrollViewer>
                    <StackPanel Spacing="15" MaxWidth="450" HorizontalAlignment="Left" Margin="10,5,0,0">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto">
                            <TextBox Grid.Column="0" Name="TxtSearchId" PlaceholderText="Поиск по ID в базе..." Background="#222222" Foreground="White" BorderBrush="#333333" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Name="BtnSearch" Click="BtnSearch_Click" Content="Найти" Background="#2D2D2D" Foreground="White" Padding="15,0"/>
                        </Grid>

                        <TextBox Name="TxtTargetName" PlaceholderText="Имя и фамилия человека..." Background="#222222" Foreground="White" BorderBrush="#333333"/>
                        <TextBlock Name="LblLifespan" Foreground="#FF4F4F" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                        
                        <ComboBox Name="CmbCause" HorizontalAlignment="Stretch" SelectedIndex="0" Background="#222222" Foreground="White" BorderBrush="#333333">
                            <ComboBoxItem>Сердечный приступ</ComboBoxItem>
                            <ComboBoxItem>Несчастный случай</ComboBoxItem>
                            <ComboBoxItem>Самоубийство</ComboBoxItem>
                            <ComboBoxItem>Автокатастрофа</ComboBoxItem>
                        </ComboBox>

                        <TextBox Name="TxtDetails" PlaceholderText="Опишите обстоятельства..." Height="100" TextWrapping="Wrap" AcceptsReturn="True" Background="#222222" Foreground="White" BorderBrush="#333333"/>
                        <Button Name="BtnExecute" Click="BtnExecute_Click" Content="Исполнить приговор" Background="#4A1525" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="12"/>
                        <TextBlock Name="LblStatus" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="👥 Жители мира">
                <Grid RowDefinitions="Auto, *" Margin="10,5,0,0">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,15">
                        <Button Name="BtnRefresh" Click="BtnRefresh_Click" Content="Обновить список" Background="#2D2D2D" Foreground="White"/>
                        <Button Name="BtnCreateHuman" Click="BtnCreateHuman_Click" Content="Создать человека в мире" Background="#222222" Foreground="White"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" Name="GridHumans" AutoGenerateColumns="True" IsReadOnly="True" GridLinesVisibility="All" Background="#1C1C1C" Foreground="White" BorderBrush="#2D2D2D"/>
                </Grid>
            </TabItem>

            <TabItem Header="🕵️ Расследование L">
                <Grid RowDefinitions="Auto, *, *" Margin="10,5,0,0">
                    <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,15">
                        <TextBlock Text="Уровень подозрения L к вам:" Foreground="#AAAAAA" FontSize="12"/>
                        <ProgressBar Name="ProgSuspicion" Value="15" Minimum="0" Maximum="100" Height="22" ShowProgressText="True" Background="#222222" Foreground="#4A1525"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Spacing="5" Margin="0,0,0,15">
                        <TextBlock Text="Досье на оперативную группу расследования:" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <DataGrid Name="GridAgents" AutoGenerateColumns="True" IsReadOnly="True" Height="150" GridLinesVisibility="All" Background="#1C1C1C" Foreground="White" BorderBrush="#2D2D2D"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Spacing="5">
                        <TextBlock Text="Лента оперативных действий L:" Foreground="White" FontWeight="Bold" FontSize="14"/>
                        <TextBox Name="TxtLogL" IsReadOnly="True" Height="100" Background="#1C1C1C" Foreground="#FF4F4F" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>